# Techla AI MCP server — environment configuration
# Copy this file to `.env` and fill in your values. `.env` is git-ignored.

# === Home Assistant (Phase 6 — optional) ===
# Long-lived access token from HA Profile → Long-Lived Access Tokens
HA_URL=http://192.168.1.50:8123
HA_TOKEN=

# === Google Calendar (Phase 7 — optional) ===
# OAuth 2.0 access token. Expires in ~1 hour.
# Use your external refresh system to keep this updated.
GOOGLE_ACCESS_TOKEN=

# === Xiaozhi MCP endpoint (REQUIRED) ===
# Get your token from xiaozhi.me agent settings → MCP endpoint
XIAOZHI_MCP_WSS=wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE

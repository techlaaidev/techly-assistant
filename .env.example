# Techla AI MCP server — environment configuration
# Copy this file to `.env` and fill in your values. `.env` is git-ignored.

# === REQUIRED: Xiaozhi MCP endpoint ===
# Get from xiaozhi.me agent settings → MCP endpoint
XIAOZHI_MCP_WSS=wss://api.xiaozhi.me/mcp/?token=YOUR_TOKEN_HERE


# === Phase 6: Home Assistant IoT (optional) ===
# Long-lived access token from HA Profile → Long-Lived Access Tokens
HA_URL=http://192.168.1.50:8123
HA_TOKEN=

# === Phase 7: Google Calendar (optional) ===
# OAuth 2.0 access token. Expires ~1h, use external refresh system.
GOOGLE_ACCESS_TOKEN=


# === Brave Search (optional) — 2000 queries/month free ===
# https://api.search.brave.com/
BRAVE_API_KEY=

# === Apify (optional) — web scraping with 4000+ Actors ===
# https://console.apify.com/account/integrations
APIFY_TOKEN=

# === Notion (optional) — workspace search ===
# https://www.notion.so/my-integrations
NOTION_TOKEN=

# === GitHub (optional) — repos / issues / PRs ===
# Personal Access Token at https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_REPO=techlaaidev/techly-assistant

# === Slack (optional) — bot messaging ===
# Bot token (xoxb-...) from https://api.slack.com/apps
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general

# === Telegram (optional) — bot notifications ===
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Proactive Scheduler (optional) — timed Telegram notifications ===
# Requires: pip install apscheduler + Telegram configured above
# Provides proactive channel (reminders, alerts) since Xiaozhi cloud
# cannot push TTS to ESP32 speaker directly.
ENABLE_SCHEDULER=
SCHEDULER_TZ=Asia/Bangkok

# === PC Control (optional) — voice-driven mouse/keyboard via PyAutoGUI ===
# Requires: pip install pyautogui pyperclip
# WARNING: gives MCP server full control of mouse + keyboard on this PC.
# Fail-safe: move cursor to (0,0) corner to abort any action.
ENABLE_PC_CONTROL=

# === Browser automation via Playwright (optional) ===
# Requires: pip install playwright && python -m playwright install chromium
# Provides semantic click/fill/scrape tools via real Chromium browser.
ENABLE_BROWSER_PLAYWRIGHT=

# === Database (optional) — SQL queries via voice ===
# DB_TYPE: "sqlite" (default) or "postgres"
# Postgres requires: pip install psycopg2-binary
DB_TYPE=sqlite
DB_PATH=data/user.db
DB_DSN=
